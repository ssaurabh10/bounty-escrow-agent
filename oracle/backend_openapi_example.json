{
  "openapi": "3.0.3",
  "info": {
    "title": "Restaurant Ordering Backend",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://restaurant-api.example.com"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/signup": {
      "post": {
        "summary": "Create customer account",
        "requestBody": {
          "required": true
        },
        "responses": {
          "201": {
            "description": "User created"
          }
        }
      }
    },
    "/login": {
      "post": {
        "summary": "Log in customer",
        "responses": {
          "200": {
            "description": "Authenticated"
          }
        }
      }
    },
    "/menu": {
      "get": {
        "summary": "List menu items",
        "responses": {
          "200": {
            "description": "Menu returned"
          }
        }
      },
      "post": {
        "summary": "Create menu item as admin",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Menu item created"
          }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Create order",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Order created"
          }
        }
      }
    },
    "/orders/{orderId}": {
      "get": {
        "summary": "Fetch order by id",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order returned"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
